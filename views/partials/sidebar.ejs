        </a>

      </li>

      <!-- TEAMS -->

      <li class="<%= currentPath.startsWith('/teams') ? 'active' : '' %>">

        <a href="/teams">

          <i class="fa-solid fa-users"></i>

          <span>Teams</span>

        </a>

      </li>

      <!-- CREATE TEAM -->

      <li>

        <a href="/teams/new">

          <i class="fa-solid fa-user-plus"></i>

          <span>Create Team</span>

        </a>

      </li>

      <!-- NEW PROJECT -->

      <li>

        <a href="/projects/new">

          <i class="fa-solid fa-plus"></i>

          <span>New Project</span>

        </a>

      </li>

    </ul>

  </div>

  <!-- FOOTER -->

  <div class="sidebar-footer">

    <div style="margin-bottom:8px;">

      Role:
      <b>MEMBER</b>

    </div>

    <div class="subtitle">

      RBAC Enabled

    </div>

