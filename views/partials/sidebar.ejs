<aside class="sidebar">

  <!-- TOP -->

  <div>

    <!-- LOGO -->

    <div style="padding:24px 20px;">

      <h2
        style="
          margin-bottom:6px;
          display:flex;
          align-items:center;
          gap:10px;
        "
      >

        💻 <span>PM System</span>

      </h2>

      <p class="tech">

        <span>Node.js + Express.js</span>

      </p>

    </div>

    <!-- MENU -->

    <ul class="menu">

      <!-- DASHBOARD -->

      <li class="<%= currentPath === '/' ? 'active' : '' %>">

        <a href="/">

          <i class="fa-solid fa-chart-pie"></i>

          <span>Dashboard</span>

        </a>

      </li>

      <!-- PROJECTS -->

      <li class="<%= currentPath.startsWith('/projects') ? 'active' : '' %>">

        <a href="/projects">

          <i class="fa-solid fa-folder"></i>

